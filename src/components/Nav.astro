---
const tabs = ['Home', 'Trailers', 'Books'];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="nav-inner flex items-center justify-between px-6 md:px-12 py-4 md:py-5">
    <a href="/" class="nav-logo flex items-baseline gap-2 min-w-0" data-tab-link="home">
      <span class="font-display text-lg md:text-2xl tracking-widest text-accent whitespace-nowrap">THOUGHTS EVOKED</span>
      <span class="font-mono text-[10px] text-text-3 tracking-widest hidden md:inline">/MEDIA</span>
    </a>

    <!-- Desktop tabs -->
    <div class="tab-group hidden md:flex gap-1">
      {tabs.map((tab) => (
        <button
          class:list={[
            'tab-btn font-mono text-xs tracking-widest uppercase px-4 md:px-5 py-2.5 border border-transparent text-text-2 rounded-full transition-all duration-200',
            tab === 'Home' ? 'active' : '',
          ]}
          data-tab={tab.toLowerCase()}
        >
          {tab}
        </button>
      ))}
    </div>

    <!-- Mobile menu trigger -->
    <button
      id="nav-menu-toggle"
      class="menu-toggle md:hidden relative w-11 h-11 flex-shrink-0 flex items-center justify-center rounded-full border border-border-2 text-text-2"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-mobile-menu"
    >
      <span class="menu-icon-bar"></span>
      <span class="menu-icon-bar"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div id="nav-mobile-menu" class="nav-mobile-menu md:hidden" aria-hidden="true">
    <div class="flex flex-col px-6 py-3 gap-1">
      {tabs.map((tab) => (
        <button
          class:list={[
            'tab-btn font-mono text-sm tracking-widest uppercase px-5 py-4 border border-transparent text-text-2 rounded-xl transition-all duration-200 text-left',
            tab === 'Home' ? 'active' : '',
          ]}
          data-tab={tab.toLowerCase()}
        >
          {tab}
        </button>
      ))}
    </div>
  </div>
</nav>

<style>
  .menu-icon-bar {
    position: absolute;
    left: 50%;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    transform: translateX(-50%);
    transition: transform 0.25s ease, top 0.25s ease;
  }
  .menu-icon-bar:nth-child(1) { top: 18px; }
  .menu-icon-bar:nth-child(2) { top: 24px; }
  .menu-toggle.open .menu-icon-bar:nth-child(1) {
    top: 21px;
    transform: translateX(-50%) rotate(45deg);
  }
  .menu-toggle.open .menu-icon-bar:nth-child(2) {
    top: 21px;
    transform: translateX(-50%) rotate(-45deg);
  }

  .nav-mobile-menu {
    max-height: 0;
    overflow: hidden;
    background: rgba(7, 7, 7, 0.97);
    backdrop-filter: blur(20px);
    border-top: 1px solid transparent;
    transition: max-height 0.3s var(--ease-out-expo), border-color 0.3s ease;
  }
  .nav-mobile-menu.open {
    max-height: 320px;
    border-top-color: var(--border);
  }
  .nav-mobile-menu .tab-btn {
    width: 100%;
    min-height: 44px;
  }
</style>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    if (!nav) return;

    window.addEventListener('scroll', () => {
      if (window.scrollY > 60) {
        nav.style.background = 'rgba(7, 7, 7, 0.92)';
        nav.style.borderBottom = '1px solid var(--border)';
        nav.style.backdropFilter = 'blur(20px)';
      } else {
        nav.style.background = 'transparent';
        nav.style.borderBottom = '1px solid transparent';
        nav.style.backdropFilter = 'none';
      }
    }, { passive: true });

    function switchTab(tabId: string) {
      const gsap = (window as any).__gsap;
      if (!gsap) return;

      const currentPage = document.querySelector('.page.active');
      const nextPage = document.getElementById(`page-${tabId}`);

      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelector(`[data-tab="${tabId}"]`)?.classList.add('active');

      if (!nextPage || currentPage === nextPage) return;

      gsap.to(currentPage, {
        opacity: 0,
        y: -12,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          currentPage?.classList.remove('active');
          nextPage.classList.add('active');
          gsap.fromTo(nextPage,
            { opacity: 0, y: 16 },
            { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out' }
          );
          (window as any).__lenis?.scrollTo(0, { immediate: true });
          (window as any).__ScrollTrigger?.refresh();
        }
      });
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        if (tabId) switchTab(tabId);
      });
    });

    const logo = document.querySelector('.nav-logo');
    if (logo) {
      logo.addEventListener('click', (e) => {
        e.preventDefault();
        switchTab('home');
      });
    }
  }

  function initMobileMenu() {
    const toggle = document.getElementById('nav-menu-toggle');
    const menu = document.getElementById('nav-mobile-menu');
    if (!toggle || !menu) return;

    function closeMenu() {
      toggle!.classList.remove('open');
      toggle!.setAttribute('aria-expanded', 'false');
      menu!.classList.remove('open');
      menu!.setAttribute('aria-hidden', 'true');
    }

    function openMenu() {
      toggle!.classList.add('open');
      toggle!.setAttribute('aria-expanded', 'true');
      menu!.classList.add('open');
      menu!.setAttribute('aria-hidden', 'false');
    }

    toggle.addEventListener('click', () => {
      menu.classList.contains('open') ? closeMenu() : openMenu();
    });

    menu.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', closeMenu);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initNav();
    initMobileMenu();
  });
</script>
