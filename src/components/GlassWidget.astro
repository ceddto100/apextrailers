---
import { BOOKS } from '../data/books';
const previewBooks = BOOKS.slice(0, 3);
---

<!-- Now Playing Widget (bottom-left) -->
<div class="glass-widget-left absolute bottom-16 left-6 md:left-12 w-52 glass rounded-2xl p-4 hidden md:block">
  <div class="flex items-center gap-3 mb-3">
    <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--accent-glow);">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--accent)"><path d="M8 5v14l11-7z"/></svg>
    </div>
    <div>
      <p class="font-mono text-[10px] text-text-3">Now Playing</p>
      <p class="font-mono text-xs text-text truncate max-w-[120px]">The AI Economy...</p>
    </div>
  </div>
  <div class="h-1 rounded-full overflow-hidden" style="background: var(--surface-3);">
    <div class="h-full rounded-full progress-bar" style="background: var(--accent);"></div>
  </div>
</div>

<!-- Select Book Widget (bottom-right) -->
<div class="glass-widget-right absolute bottom-16 right-6 md:right-12 w-52 glass rounded-2xl p-4 hidden md:block">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-sm">&#128214;</span>
    <p class="font-mono text-[10px] text-text-3 tracking-widest uppercase">Select Book</p>
  </div>
  <div class="flex flex-col gap-1.5">
    {previewBooks.map((book) => (
      <div class="font-mono text-xs text-text-2 px-2.5 py-1.5 rounded-lg border border-border hover:border-accent hover:text-accent cursor-pointer transition-all duration-200" style={`background: var(--surface-3);`}>
        {book.title.length > 18 ? book.title.slice(0, 18) + '...' : book.title}
      </div>
    ))}
  </div>
</div>
