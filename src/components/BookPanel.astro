---
import type { Book } from '../data/books';

interface Props {
  book: Book;
}

const { book } = Astro.props;
const hasPlatformLink = Boolean(book.buyUrl && book.buyUrl !== '#');
---

<!-- Trigger button -->
<button
  class="panel-toggle font-mono text-xs tracking-widest uppercase text-text-2 flex items-center gap-2 py-3 hover:text-accent transition-colors duration-200"
  data-panel-id={`panel-${book.id}`}
>
  <span class="toggle-icon transition-transform duration-300 inline-block">&#9660;</span>
  <span class="toggle-label">About This Book</span>
</button>

<!-- Expandable panel -->
<div
  id={`panel-${book.id}`}
  class="book-panel overflow-hidden"
  style="height: 0; opacity: 0;"
  aria-hidden="true"
>
  <div class="glass rounded-2xl p-4 md:p-5 mt-2 border-l-2" style={`border-left-color: ${book.accentHex};`}>
    <div class="flex flex-col gap-4">
      <!-- Book details -->
      <div class="flex flex-col gap-2">
        <p class="font-mono text-[10px] tracking-widest uppercase" style={`color: ${book.accentHex};`}>{book.genre}</p>
        <h3 class="font-display text-xl tracking-wide">{book.title}</h3>
        <p class="text-sm text-text-2 leading-relaxed italic">{book.tagline}</p>
        <p class="text-sm text-text-2 leading-relaxed">{book.description}</p>
      </div>

      <!-- Meta row -->
      <div class="flex flex-wrap gap-4 pt-2 border-t border-border font-mono text-xs text-text-3">
        <span>Pages: <span class="text-text">{book.pages}</span></span>
        <span>Format: <span class="text-text">Digital</span></span>
        <span>DRM: <span class="text-text">None</span></span>
        <span>Price: <span class="text-text" style={`color: ${book.accentHex};`}>{book.price}</span></span>
      </div>

      <!-- CTA row -->
      <div class="flex flex-wrap items-center gap-4">
        {hasPlatformLink ? (
          <a
            href={book.buyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase px-5 py-2.5 text-bg rounded-full hover:brightness-110 transition-all duration-200"
            style={`background: ${book.accentHex};`}
          >
            {book.ctaLabel} &rarr;
          </a>
        ) : (
          <span class="font-mono text-xs text-text-3">Platform link coming soon</span>
        )}
        <button
          class="panel-close font-mono text-xs text-text-3 hover:text-text transition-colors"
          data-panel-id={`panel-${book.id}`}
        >
          &#10005; Close
        </button>
      </div>
    </div>
  </div>
</div>
