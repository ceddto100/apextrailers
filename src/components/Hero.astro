---
import { BOOKS } from '../data/books';

// Generate particle positions at build time
const particles = Array.from({ length: 35 }, (_, i) => ({
  x: Math.random() * 100,
  y: Math.random() * 100,
  delay: (Math.random() * 8).toFixed(1),
  duration: (6 + Math.random() * 10).toFixed(1),
  size: (1 + Math.random() * 2).toFixed(1),
  drift: (-40 + Math.random() * 80).toFixed(0),
}));
---

<section class="relative w-full min-h-screen flex items-center overflow-hidden">
  <!-- Layer 0: Base background -->
  <div class="absolute inset-0" style="background: var(--bg);" aria-hidden="true"></div>

  <!-- Layer 1: Ambient radial glow behind globe -->
  <div class="hero-ambient-glow" aria-hidden="true"></div>

  <!-- Layer 2: Light rays emanating from globe center -->
  <div class="hero-rays" aria-hidden="true">
    <div class="hero-ray" style="top: 38%; transform: rotate(-22deg);"></div>
    <div class="hero-ray" style="top: 46%; transform: rotate(6deg); opacity: 0.7;"></div>
    <div class="hero-ray hero-ray--wide" style="top: 52%; transform: rotate(-10deg);"></div>
    <div class="hero-ray" style="top: 42%; transform: rotate(18deg); opacity: 0.5;"></div>
    <div class="hero-ray" style="top: 58%; transform: rotate(-35deg); opacity: 0.4;"></div>
    <div class="hero-ray hero-ray--wide" style="top: 35%; transform: rotate(30deg); opacity: 0.3;"></div>
    <div class="hero-ray" style="top: 62%; transform: rotate(-5deg); opacity: 0.6;"></div>
  </div>

  <!-- Layer 3: Floating particles -->
  <div class="hero-particles" aria-hidden="true">
    {particles.map((p) => (
      <div
        class="hero-particle"
        style={`left:${p.x}%; top:${p.y}%; --dur:${p.duration}s; --delay:${p.delay}s; --drift:${p.drift}px; --size:${p.size}px;`}
      />
    ))}
  </div>

  <!-- Layer 4: Wireframe globe canvas -->
  <div class="hero-globe-wrap">
    <canvas id="hero-globe"></canvas>
  </div>

  <!-- Layer 5: Hero content (left-aligned, above globe) -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12 pt-28 pb-36">
    <div class="max-w-xl">
      <!-- Badge -->
      <div class="hero-badge mb-6">
        <span class="inline-flex items-center gap-2 glass rounded-full px-4 py-2 font-mono text-xs tracking-widest uppercase text-text-2">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
          AI Ebook Trailers
        </span>
      </div>

      <!-- Title -->
      <h1 class="font-display tracking-wide leading-[0.9] mb-6">
        <span class="hero-title-line-1 text-[clamp(52px,11vw,130px)]">STORIES</span>
        <span class="hero-title-line-2 text-[clamp(52px,11vw,130px)]">THAT HIT.</span>
      </h1>

      <!-- Subtitle -->
      <p class="hero-subtitle max-w-md text-text-2 text-lg md:text-xl leading-relaxed mb-10">
        Cinematic trailers for books that demand your attention.<br/>
        Watch. Buy. Read.
      </p>

      <!-- CTAs -->
      <div class="hero-cta flex flex-wrap gap-4">
        <button
          class="group inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase px-7 py-3.5 bg-accent text-bg rounded-full hover:bg-white transition-colors duration-200 hover:shadow-[0_0_30px_rgba(167,139,250,0.3)]"
          data-tab-target="trailers"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="transition-transform group-hover:scale-110"><path d="M8 5v14l11-7z"/></svg>
          Watch Trailers
        </button>
        <button
          class="inline-flex items-center gap-3 font-mono text-xs tracking-widest uppercase px-7 py-3.5 border border-border-2 text-text-2 rounded-full hover:border-accent hover:text-accent transition-all duration-200"
          data-tab-target="books"
        >
          <span class="w-2 h-2 rounded-full border border-text-3"></span>
          Browse Books
        </button>
      </div>
    </div>
  </div>

  <!-- Layer 6: Stats bar at bottom -->
  <div class="hero-stats absolute bottom-0 left-0 right-0 z-10 border-t border-border">
    <div class="flex items-center justify-center gap-4 md:gap-8 px-6 py-4 text-center flex-wrap">
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">
        <span class="stat-number text-text font-display text-lg" data-target={BOOKS.length}>0</span> Titles
      </div>
      <span class="text-border-2 hidden md:inline">&middot;</span>
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">Digital Only</div>
      <span class="text-border-2 hidden md:inline">&middot;</span>
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">Instant Access</div>
      <span class="text-border-2 hidden md:inline">&middot;</span>
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">No DRM</div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  /* ========================================
     WIREFRAME GLOBE — Canvas renderer
     ======================================== */
  /** Book cover data for orbiting images */
  interface CoverEntry {
    src: string;
    title: string;
    lat: number;
    lon: number;
    accentHex: string;
    img: HTMLImageElement | null;
    loaded: boolean;
  }

  class WireframeGlobe {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private dpr: number;
    private w = 0;
    private h = 0;
    private cx = 0;
    private cy = 0;
    private r = 0;
    private animId = 0;
    private covers: CoverEntry[] = [];

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.dpr = Math.min(window.devicePixelRatio || 1, 2);
      this.resize();
      window.addEventListener('resize', () => this.resize());
      this.initCovers();
    }

    /** Preload book cover images and set orbital positions */
    initCovers() {
      const coverData = [
        { src: '/AI_reviewer.jpeg',       title: 'AI Reviewer',       lat: 25,  lon: 0,   accentHex: '#4A9EDB' },
        { src: '/Bending_the_rules.jpeg',  title: 'Bending the Rules', lat: -10, lon: 90,  accentHex: '#C8A96E' },
        { src: '/Chess_correlation.jpeg',  title: 'Chess Correlation', lat: 20,  lon: 180, accentHex: '#9B59B6' },
        { src: '/The_war.jpeg',            title: 'The War',           lat: -15, lon: 270, accentHex: '#E74C3C' },
      ];

      this.covers = coverData.map(c => {
        const img = new Image();
        const entry: CoverEntry = { ...c, img: null, loaded: false };
        img.onload = () => { entry.img = img; entry.loaded = true; };
        img.onerror = () => { entry.loaded = false; };
        img.src = c.src;
        return entry;
      });
    }

    resize() {
      const rect = this.canvas.parentElement!.getBoundingClientRect();
      this.w = rect.width;
      this.h = rect.height;
      this.canvas.width = this.w * this.dpr;
      this.canvas.height = this.h * this.dpr;
      this.canvas.style.width = this.w + 'px';
      this.canvas.style.height = this.h + 'px';
      this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
      this.cx = this.w / 2;
      this.cy = this.h / 2;
      this.r = Math.min(this.w, this.h) * 0.42;
    }

    /** Convert lat/lon to 3D vector, apply Y-rotation + X-tilt */
    project(lat: number, lon: number, rotY: number): { x: number; y: number; z: number } {
      const phi = (90 - lat) * Math.PI / 180;
      const theta = lon * Math.PI / 180 + rotY;
      const tilt = 0.38;

      const x = Math.sin(phi) * Math.cos(theta);
      const y = Math.cos(phi);
      const z = Math.sin(phi) * Math.sin(theta);

      const ct = Math.cos(tilt), st = Math.sin(tilt);
      return {
        x: this.cx + x * this.r,
        y: this.cy - (y * ct - z * st) * this.r,
        z: y * st + z * ct,
      };
    }

    /** Project with custom radius (for terrain displacement) */
    projectR(lat: number, lon: number, rotY: number, radius: number) {
      const phi = (90 - lat) * Math.PI / 180;
      const theta = lon * Math.PI / 180 + rotY;
      const tilt = 0.38;

      const x = Math.sin(phi) * Math.cos(theta);
      const y = Math.cos(phi);
      const z = Math.sin(phi) * Math.sin(theta);

      const ct = Math.cos(tilt), st = Math.sin(tilt);
      return {
        x: this.cx + x * radius,
        y: this.cy - (y * ct - z * st) * radius,
        z: y * st + z * ct,
      };
    }

    render(time: number) {
      const { ctx, w, h, cx, cy, r } = this;
      ctx.clearRect(0, 0, w, h);

      const rotY = time * 0.00022;

      // === BLOOM GLOW ===
      const g1 = ctx.createRadialGradient(cx, cy, 0, cx, cy, r * 1.7);
      g1.addColorStop(0, 'rgba(124, 58, 237, 0.12)');
      g1.addColorStop(0.25, 'rgba(124, 58, 237, 0.06)');
      g1.addColorStop(0.5, 'rgba(76, 29, 149, 0.025)');
      g1.addColorStop(1, 'transparent');
      ctx.fillStyle = g1;
      ctx.beginPath();
      ctx.arc(cx, cy, r * 1.7, 0, Math.PI * 2);
      ctx.fill();

      // === GRID — Back-face pass (dim) ===
      ctx.save();
      ctx.strokeStyle = 'rgba(167, 139, 250, 0.035)';
      ctx.lineWidth = 0.5;

      // Back latitude lines
      for (let lat = -75; lat <= 75; lat += 15) {
        this.drawLatSegments(lat, rotY, false);
      }
      // Back longitude lines
      for (let lon = 0; lon < 360; lon += 18) {
        this.drawLonSegments(lon, rotY, false);
      }
      ctx.restore();

      // === GRID — Front-face pass (bright) ===
      ctx.save();
      ctx.strokeStyle = 'rgba(167, 139, 250, 0.14)';
      ctx.lineWidth = 0.7;

      for (let lat = -75; lat <= 75; lat += 15) {
        this.drawLatSegments(lat, rotY, true);
      }
      ctx.strokeStyle = 'rgba(167, 139, 250, 0.10)';
      for (let lon = 0; lon < 360; lon += 18) {
        this.drawLonSegments(lon, rotY, true);
      }
      ctx.restore();

      // === TERRAIN — Landscape ridge ===
      this.drawTerrain(rotY, time);

      // === BRIGHT EQUATOR ===
      this.drawEquator(rotY);

      // === ORBITING BOOK COVERS ===
      this.drawCovers(rotY);

      // === INTERSECTION DOTS (front-face only) ===
      this.drawDots(rotY);

      // === OUTER RIM ===
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(167, 139, 250, 0.08)';
      ctx.lineWidth = 1.2;
      ctx.stroke();

      // Subtle secondary rim glow
      ctx.beginPath();
      ctx.arc(cx, cy, r + 4, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(167, 139, 250, 0.03)';
      ctx.lineWidth = 6;
      ctx.stroke();
    }

    /** Draw latitude line segments for front or back face */
    drawLatSegments(lat: number, rotY: number, front: boolean) {
      const ctx = this.ctx;
      let points: { x: number; y: number }[] = [];

      for (let lon = 0; lon <= 360; lon += 3) {
        const p = this.project(lat, lon, rotY);
        const isFront = p.z >= 0;

        if (isFront === front) {
          points.push(p);
        } else {
          if (points.length > 1) {
            ctx.beginPath();
            ctx.moveTo(points[0].x, points[0].y);
            for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
            ctx.stroke();
          }
          points = [];
        }
      }
      if (points.length > 1) {
        ctx.beginPath();
        ctx.moveTo(points[0].x, points[0].y);
        for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
        ctx.stroke();
      }
    }

    /** Draw longitude line segments for front or back face */
    drawLonSegments(lon: number, rotY: number, front: boolean) {
      const ctx = this.ctx;
      let points: { x: number; y: number }[] = [];

      for (let lat = -90; lat <= 90; lat += 3) {
        const p = this.project(lat, lon, rotY);
        const isFront = p.z >= 0;

        if (isFront === front) {
          points.push(p);
        } else {
          if (points.length > 1) {
            ctx.beginPath();
            ctx.moveTo(points[0].x, points[0].y);
            for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
            ctx.stroke();
          }
          points = [];
        }
      }
      if (points.length > 1) {
        ctx.beginPath();
        ctx.moveTo(points[0].x, points[0].y);
        for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
        ctx.stroke();
      }
    }

    /** Draw bright equator line (front half) */
    drawEquator(rotY: number) {
      const ctx = this.ctx;
      let points: { x: number; y: number }[] = [];

      for (let lon = 0; lon <= 360; lon += 2) {
        const p = this.project(0, lon, rotY);
        if (p.z >= 0) {
          points.push(p);
        } else {
          if (points.length > 1) {
            ctx.beginPath();
            ctx.moveTo(points[0].x, points[0].y);
            for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
            ctx.strokeStyle = 'rgba(167, 139, 250, 0.3)';
            ctx.lineWidth = 1;
            ctx.stroke();
          }
          points = [];
        }
      }
      if (points.length > 1) {
        ctx.beginPath();
        ctx.moveTo(points[0].x, points[0].y);
        for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
        ctx.strokeStyle = 'rgba(167, 139, 250, 0.3)';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    /** Draw animated terrain landscape across the globe */
    drawTerrain(rotY: number, time: number) {
      const { ctx, r } = this;
      const terrainTop: { x: number; y: number; z: number }[] = [];
      const terrainBase: { x: number; y: number; z: number }[] = [];

      for (let lon = 0; lon <= 360; lon += 2) {
        const lonRad = lon * Math.PI / 180;

        // Multi-frequency terrain height
        const h =
          Math.sin(lonRad * 3 + time * 0.0005) * 14 +
          Math.sin(lonRad * 7 - time * 0.0003) * 8 +
          Math.sin(lonRad * 13 + time * 0.0008) * 4 +
          Math.sin(lonRad * 21 - time * 0.0006) * 2;

        // Terrain peak latitude (displaces upward from equator baseline)
        const peakLat = Math.max(-8, h);

        const pTop = this.project(peakLat, lon, rotY);
        const pBase = this.project(-18, lon, rotY);

        terrainTop.push(pTop);
        terrainBase.push(pBase);
      }

      // Find front-facing segments
      const segments: number[][] = [];
      let current: number[] = [];

      for (let i = 0; i < terrainTop.length; i++) {
        if (terrainTop[i].z >= -0.05) {
          current.push(i);
        } else {
          if (current.length > 2) segments.push([...current]);
          current = [];
        }
      }
      if (current.length > 2) segments.push(current);

      for (const seg of segments) {
        // Filled dark terrain body
        ctx.beginPath();
        ctx.moveTo(terrainTop[seg[0]].x, terrainTop[seg[0]].y);
        for (let i = 1; i < seg.length; i++) {
          ctx.lineTo(terrainTop[seg[i]].x, terrainTop[seg[i]].y);
        }
        for (let i = seg.length - 1; i >= 0; i--) {
          ctx.lineTo(terrainBase[seg[i]].x, terrainBase[seg[i]].y);
        }
        ctx.closePath();
        ctx.fillStyle = 'rgba(7, 7, 7, 0.7)';
        ctx.fill();

        // Glowing ridge line
        ctx.beginPath();
        ctx.moveTo(terrainTop[seg[0]].x, terrainTop[seg[0]].y);
        for (let i = 1; i < seg.length; i++) {
          ctx.lineTo(terrainTop[seg[i]].x, terrainTop[seg[i]].y);
        }
        ctx.strokeStyle = 'rgba(167, 139, 250, 0.55)';
        ctx.lineWidth = 1.5;
        ctx.shadowColor = 'rgba(167, 139, 250, 0.5)';
        ctx.shadowBlur = 15;
        ctx.stroke();
        ctx.shadowBlur = 0;

        // Secondary glow pass
        ctx.strokeStyle = 'rgba(124, 58, 237, 0.2)';
        ctx.lineWidth = 4;
        ctx.stroke();
      }
    }

    /** Draw glowing dots at grid intersections on front face */
    drawDots(rotY: number) {
      const { ctx, r } = this;

      for (let lat = -75; lat <= 75; lat += 15) {
        for (let lon = 0; lon < 360; lon += 18) {
          const p = this.project(lat, lon, rotY);
          if (p.z > 0.1) {
            const depth = (p.z + 1) / 2;
            const alpha = 0.12 + depth * 0.4;
            const size = 0.6 + depth * 1.4;

            // Glow
            ctx.beginPath();
            ctx.arc(p.x, p.y, size + 2, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(167, 139, 250, ${alpha * 0.15})`;
            ctx.fill();

            // Core dot
            ctx.beginPath();
            ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(167, 139, 250, ${alpha})`;
            ctx.fill();
          }
        }
      }
    }

    /** Draw orbiting book covers on the globe surface */
    drawCovers(rotY: number) {
      const { ctx, r } = this;

      // Sort covers by depth so back-face covers draw first
      const projected = this.covers.map((cover) => {
        const p = this.project(cover.lat, cover.lon, rotY);
        return { cover, p };
      });
      projected.sort((a, b) => a.p.z - b.p.z);

      for (const { cover, p } of projected) {
        // Depth factor: 0 (back) to 1 (front)
        const depth = (p.z + 1) / 2;

        // Skip covers far behind the globe (fully occluded)
        if (depth < 0.15) continue;

        // Cover dimensions scale with depth (perspective)
        const baseW = r * 0.22;
        const baseH = baseW * 1.4; // ~book aspect ratio
        const scale = 0.4 + depth * 0.6;
        const cw = baseW * scale;
        const ch = baseH * scale;

        // Opacity: front-face is bright, back-face fades out
        const alpha = Math.pow(depth, 1.8) * 0.9;
        if (alpha < 0.03) continue;

        ctx.save();
        ctx.globalAlpha = alpha;

        const dx = p.x - cw / 2;
        const dy = p.y - ch / 2;

        if (cover.loaded && cover.img) {
          // === Draw real image ===
          // Accent glow behind cover
          ctx.shadowColor = cover.accentHex;
          ctx.shadowBlur = 20 * depth;
          ctx.fillStyle = 'rgba(0,0,0,0.5)';
          ctx.fillRect(dx, dy, cw, ch);
          ctx.shadowBlur = 0;

          // Draw the image
          ctx.drawImage(cover.img, dx, dy, cw, ch);

          // Accent border
          ctx.strokeStyle = cover.accentHex;
          ctx.lineWidth = 1.5 * scale;
          ctx.globalAlpha = alpha * 0.6;
          ctx.strokeRect(dx, dy, cw, ch);
        } else {
          // === Fallback: gradient cover with title ===
          this.drawFallbackCover(dx, dy, cw, ch, cover, depth);
        }

        ctx.restore();
      }
    }

    /** Draw a canvas-generated book cover when image isn't loaded */
    drawFallbackCover(x: number, y: number, w: number, h: number, cover: CoverEntry, depth: number) {
      const { ctx } = this;

      // Glow behind
      ctx.shadowColor = cover.accentHex;
      ctx.shadowBlur = 18 * depth;

      // Gradient background
      const grad = ctx.createLinearGradient(x, y, x + w, y + h);
      grad.addColorStop(0, 'rgba(15, 15, 15, 0.9)');
      grad.addColorStop(1, 'rgba(30, 30, 30, 0.9)');
      ctx.fillStyle = grad;
      ctx.fillRect(x, y, w, h);
      ctx.shadowBlur = 0;

      // Accent bar at top
      ctx.fillStyle = cover.accentHex;
      ctx.globalAlpha = ctx.globalAlpha * 0.7;
      ctx.fillRect(x, y, w, 3 * (w / (this.r * 0.22)));
      ctx.globalAlpha = ctx.globalAlpha / 0.7;

      // Title text
      const fontSize = Math.max(8, w * 0.13);
      ctx.fillStyle = '#F0EDE8';
      ctx.font = `${fontSize}px 'Bebas Neue', sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      // Word-wrap title
      const words = cover.title.split(' ');
      const lineHeight = fontSize * 1.2;
      const lines: string[] = [];
      let currentLine = '';
      for (const word of words) {
        const testLine = currentLine ? currentLine + ' ' + word : word;
        if (ctx.measureText(testLine).width > w * 0.8 && currentLine) {
          lines.push(currentLine);
          currentLine = word;
        } else {
          currentLine = testLine;
        }
      }
      if (currentLine) lines.push(currentLine);

      const startY = y + h / 2 - ((lines.length - 1) * lineHeight) / 2;
      lines.forEach((line, i) => {
        ctx.fillText(line, x + w / 2, startY + i * lineHeight);
      });

      // Border
      ctx.strokeStyle = cover.accentHex;
      ctx.lineWidth = 1;
      ctx.globalAlpha = ctx.globalAlpha * 0.5;
      ctx.strokeRect(x, y, w, h);
      ctx.globalAlpha = ctx.globalAlpha / 0.5;
    }

    start() {
      const loop = (time: number) => {
        this.render(time);
        this.animId = requestAnimationFrame(loop);
      };
      this.animId = requestAnimationFrame(loop);
    }

    stop() {
      cancelAnimationFrame(this.animId);
    }
  }

  /* ========================================
     INIT — Globe + GSAP Entrance Sequence
     ======================================== */
  function initHero() {
    // Start the wireframe globe
    const canvas = document.getElementById('hero-globe') as HTMLCanvasElement;
    if (canvas) {
      const globe = new WireframeGlobe(canvas);
      globe.start();
    }

    // Cinematic entrance sequence
    const tl = gsap.timeline({ delay: 0.15 });

    // 1. Globe materializes
    tl.fromTo('.hero-globe-wrap',
      { opacity: 0, scale: 0.8 },
      { opacity: 1, scale: 1, duration: 1.6, ease: 'power3.out' }
    )
    // 2. Ambient glow blooms
    .fromTo('.hero-ambient-glow',
      { opacity: 0, scale: 0.6 },
      { opacity: 1, scale: 1, duration: 1.4, ease: 'power2.out' },
      '-=1.2'
    )
    // 3. Light rays sweep in
    .fromTo('.hero-rays',
      { opacity: 0 },
      { opacity: 1, duration: 1.2, ease: 'power2.out' },
      '-=0.8'
    )
    // 4. Badge drops in
    .fromTo('.hero-badge',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' },
      '-=0.6'
    )
    // 5. Title reveals left-to-right
    .to('.hero-title-line-1', {
      clipPath: 'inset(0 0% 0 0)',
      duration: 0.9, ease: 'power4.out'
    }, '-=0.2')
    .to('.hero-title-line-2', {
      clipPath: 'inset(0 0% 0 0)',
      duration: 0.9, ease: 'power4.out'
    }, '-=0.55')
    // 6. Subtitle fades up
    .fromTo('.hero-subtitle',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
      '-=0.35'
    )
    // 7. CTAs appear
    .fromTo('.hero-cta',
      { opacity: 0, y: 16 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' },
      '-=0.25'
    )
    // 8. Particles drift in
    .fromTo('.hero-particles',
      { opacity: 0 },
      { opacity: 1, duration: 2, ease: 'power1.out' },
      '-=1'
    )
    // 9. Stats bar rises
    .fromTo('.hero-stats',
      { opacity: 0, y: 10 },
      { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' },
      '-=1.2'
    );

    // Counter animation for stat numbers
    document.querySelectorAll('.stat-number').forEach((el) => {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      gsap.fromTo(el, { textContent: '0' }, {
        textContent: target,
        duration: 1.5,
        delay: 2,
        ease: 'power2.out',
        snap: { textContent: 1 },
      });
    });

    // Hero CTA buttons → switch tabs
    document.querySelectorAll('[data-tab-target]').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab-target');
        if (tabId) {
          const tabBtn = document.querySelector(`[data-tab="${tabId}"]`) as HTMLButtonElement;
          tabBtn?.click();
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initHero);
</script>
