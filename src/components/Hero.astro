---
import GlassWidget from './GlassWidget.astro';
import { BOOKS } from '../data/books';
---

<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Layer 1: Animated gradient mesh -->
  <div class="hero-bg" aria-hidden="true"></div>

  <!-- Layer 2: Giant watermark -->
  <div class="hero-watermark" aria-hidden="true">APEX TRAILERS</div>

  <!-- Layer 3: Hero content -->
  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 md:px-12 pt-24 pb-32">
    <!-- Badge -->
    <div class="hero-badge gsap-fade-up mb-6">
      <span class="inline-flex items-center gap-2 glass rounded-full px-4 py-2 font-mono text-xs tracking-widest uppercase text-text-2">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        AI Ebook Trailers
      </span>
    </div>

    <!-- Title -->
    <h1 class="font-display tracking-wide leading-[0.95] mb-6">
      <span class="hero-title-line-1 text-[clamp(48px,10vw,120px)]">STORIES</span>
      <span class="hero-title-line-2 text-[clamp(48px,10vw,120px)]">THAT HIT.</span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-subtitle gsap-fade-up max-w-lg text-text-2 text-lg md:text-xl leading-relaxed mb-8">
      Cinematic trailers for books that demand your attention.<br/>
      Watch. Buy. Read.
    </p>

    <!-- CTAs -->
    <div class="hero-cta gsap-fade-up flex flex-wrap gap-4">
      <button
        class="watch-trailers-btn inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase px-6 py-3 bg-accent text-bg rounded-full hover:bg-white transition-colors duration-200"
        data-tab-target="trailers"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Watch Trailers
      </button>
      <button
        class="browse-books-btn inline-flex items-center gap-3 font-mono text-xs tracking-widest uppercase px-6 py-3 border border-border-2 text-text-2 rounded-full hover:border-accent hover:text-accent transition-all duration-200"
        data-tab-target="books"
      >
        <span class="w-2 h-2 rounded-full border border-text-3"></span>
        Browse Books
      </button>
    </div>
  </div>

  <!-- Layer 3b: Glass widgets -->
  <GlassWidget />

  <!-- Layer 4: Stats bar -->
  <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-border">
    <div class="flex items-center justify-center gap-4 md:gap-8 px-6 py-4 text-center flex-wrap">
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">
        <span class="stat-number text-text font-display text-lg" data-target={BOOKS.length}>0</span> Titles
      </div>
      <span class="text-border-2 hidden md:inline">&middot;</span>
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">Digital Only</div>
      <span class="text-border-2 hidden md:inline">&middot;</span>
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">Instant Access</div>
      <span class="text-border-2 hidden md:inline">&middot;</span>
      <div class="font-mono text-xs tracking-widest text-text-3 uppercase">No DRM</div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initHero() {
    const tl = gsap.timeline({ delay: 0.3 });

    tl.to('.hero-badge', {
      opacity: 1, y: 0, duration: 0.6, ease: 'power3.out'
    })
    .to('.hero-title-line-1', {
      clipPath: 'inset(0 0% 0 0)',
      duration: 0.9, ease: 'power4.out'
    }, '-=0.3')
    .to('.hero-title-line-2', {
      clipPath: 'inset(0 0% 0 0)',
      duration: 0.9, ease: 'power4.out'
    }, '-=0.6')
    .to('.hero-subtitle', {
      opacity: 1, y: 0, duration: 0.7, ease: 'power3.out'
    }, '-=0.4')
    .to('.hero-cta', {
      opacity: 1, y: 0, duration: 0.6, ease: 'power3.out'
    }, '-=0.3')
    .to('.glass-widget-left', {
      opacity: 1, x: 0, duration: 0.8, ease: 'power3.out'
    }, '-=0.5')
    .to('.glass-widget-right', {
      opacity: 1, x: 0, duration: 0.8, ease: 'power3.out'
    }, '-=0.7');

    // Counter animation for stat numbers
    document.querySelectorAll('.stat-number').forEach((el) => {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      gsap.fromTo(el, { textContent: '0' }, {
        textContent: target,
        duration: 1.5,
        delay: 1.2,
        ease: 'power2.out',
        snap: { textContent: 1 },
      });
    });

    // Hero CTA buttons → switch tabs
    document.querySelectorAll('[data-tab-target]').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab-target');
        if (tabId) {
          const tabBtn = document.querySelector(`[data-tab="${tabId}"]`) as HTMLButtonElement;
          tabBtn?.click();
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initHero);
</script>
