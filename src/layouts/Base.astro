---
interface Props {
  title?: string;
}
const { title = 'Thoughts Evoked Media — Book Promo Trailers' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Short-form cinematic trailers for books that move you. Discover, watch, and read." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <!-- Site-wide fixed curved background -->
  <canvas id="site-bg" aria-hidden="true"></canvas>
  <!-- All page content sits above the canvas -->
  <div id="site-content">
    <slot />
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/animations.css';

  #site-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  #site-content {
    position: relative;
    z-index: 1;
  }
</style>

<script>
  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    smoothWheel: true,
  });

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
  gsap.ticker.lagSmoothing(0);

  (window as any).__lenis = lenis;
  (window as any).__gsap = gsap;
  (window as any).__ScrollTrigger = ScrollTrigger;

  /* =============================================
     SITE-WIDE CURVED BACKGROUND — Canvas renderer
     ============================================= */
  class CurvedBackground {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.render();
      window.addEventListener('resize', () => this.render());
    }

    render() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const w = window.innerWidth;
      const h = window.innerHeight;
      this.canvas.width = w * dpr;
      this.canvas.height = h * dpr;
      this.canvas.style.width = w + 'px';
      this.canvas.style.height = h + 'px';
      this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      this.draw(w, h);
    }

    draw(w: number, h: number) {
      const ctx = this.ctx;

      ctx.fillStyle = '#070707';
      ctx.fillRect(0, 0, w, h);

      // ── Layer 1: large bottom sheet with gentle diagonal sweep ──
      ctx.beginPath();
      ctx.moveTo(-10, h * 0.62);
      ctx.bezierCurveTo(w * 0.28, h * 0.53, w * 0.62, h * 0.37, w + 10, h * 0.2);
      ctx.lineTo(w + 10, h + 10);
      ctx.lineTo(-10, h + 10);
      ctx.closePath();
      ctx.fillStyle = '#0e0e0e';
      ctx.shadowColor = 'rgba(0,0,0,0.92)';
      ctx.shadowBlur = 55;
      ctx.shadowOffsetY = -10;
      ctx.fill();
      ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
      ctx.beginPath();
      ctx.moveTo(-10, h * 0.62);
      ctx.bezierCurveTo(w * 0.28, h * 0.53, w * 0.62, h * 0.37, w + 10, h * 0.2);
      ctx.strokeStyle = 'rgba(255,255,255,0.04)';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // ── Layer 2: upper-left curved sheet ──
      ctx.beginPath();
      ctx.moveTo(-10, -10);
      ctx.lineTo(w * 0.6, -10);
      ctx.bezierCurveTo(w * 0.55, h * 0.18, w * 0.41, h * 0.38, w * 0.17, h * 0.57);
      ctx.lineTo(-10, h * 0.62);
      ctx.closePath();
      ctx.fillStyle = '#111111';
      ctx.shadowColor = 'rgba(0,0,0,0.88)';
      ctx.shadowBlur = 45;
      ctx.shadowOffsetX = 12;
      ctx.fill();
      ctx.shadowBlur = 0; ctx.shadowOffsetX = 0;
      ctx.beginPath();
      ctx.moveTo(w * 0.6, -10);
      ctx.bezierCurveTo(w * 0.55, h * 0.18, w * 0.41, h * 0.38, w * 0.17, h * 0.57);
      ctx.strokeStyle = 'rgba(255,255,255,0.055)';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // ── Layer 3: upper-right inset sheet ──
      ctx.beginPath();
      ctx.moveTo(w * 0.6, -10);
      ctx.lineTo(w + 10, -10);
      ctx.lineTo(w + 10, h * 0.2);
      ctx.bezierCurveTo(w * 0.83, h * 0.28, w * 0.67, h * 0.38, w * 0.51, h * 0.5);
      ctx.bezierCurveTo(w * 0.44, h * 0.43, w * 0.5, h * 0.19, w * 0.6, -10);
      ctx.closePath();
      ctx.fillStyle = '#0c0c0c';
      ctx.shadowColor = 'rgba(0,0,0,0.82)';
      ctx.shadowBlur = 38;
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.beginPath();
      ctx.moveTo(w * 0.51, h * 0.5);
      ctx.bezierCurveTo(w * 0.67, h * 0.38, w * 0.83, h * 0.28, w + 10, h * 0.2);
      ctx.strokeStyle = 'rgba(255,255,255,0.035)';
      ctx.lineWidth = 1;
      ctx.stroke();

      // ── Layer 4: lower-left folded edge ──
      ctx.beginPath();
      ctx.moveTo(-10, h * 0.62);
      ctx.bezierCurveTo(w * 0.12, h * 0.66, w * 0.26, h * 0.72, w * 0.42, h * 0.68);
      ctx.bezierCurveTo(w * 0.3, h * 0.8, w * 0.14, h * 0.84, -10, h * 0.78);
      ctx.closePath();
      ctx.fillStyle = '#101010';
      ctx.shadowColor = 'rgba(0,0,0,0.75)';
      ctx.shadowBlur = 28;
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.beginPath();
      ctx.moveTo(-10, h * 0.62);
      ctx.bezierCurveTo(w * 0.12, h * 0.66, w * 0.26, h * 0.72, w * 0.42, h * 0.68);
      ctx.strokeStyle = 'rgba(255,255,255,0.03)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  }

  const siteBg = document.getElementById('site-bg') as HTMLCanvasElement;
  if (siteBg) new CurvedBackground(siteBg);
</script>
