---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrailerCard from '../components/TrailerCard.astro';
import BookCard from '../components/BookCard.astro';
import FilterBar from '../components/FilterBar.astro';
import Footer from '../components/Footer.astro';
import { BOOKS } from '../data/books';

const featuredBooks = BOOKS.slice(0, 3);
---

<Base>
  <Nav />

  <!-- PAGE: Home -->
  <div id="page-home" class="page active">
    <Hero />

    <!-- Featured Trailers section -->
    <section class="py-20 px-6 md:px-12 border-t border-border">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-10 gsap-fade-up">
          <div>
            <span class="font-mono text-xs tracking-widest uppercase text-accent mb-2 block">Latest Drops</span>
            <h2 class="font-display text-[clamp(32px,5vw,56px)] tracking-wide leading-[0.95]">FEATURED TRAILERS</h2>
          </div>
          <button
            class="font-mono text-xs tracking-widest uppercase text-text-3 hover:text-accent transition-colors duration-200 flex items-center gap-2"
            data-tab-target="trailers"
          >
            View All &rarr;
          </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredBooks.map((book, i) => (
            <TrailerCard book={book} index={i} panelIdPrefix="home-trailers" />
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Books section -->
    <section class="py-20 px-6 md:px-12 border-t border-border">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-10 gsap-fade-up">
          <div>
            <span class="font-mono text-xs tracking-widest uppercase text-accent mb-2 block">The Collection</span>
            <h2 class="font-display text-[clamp(32px,5vw,56px)] tracking-wide leading-[0.95]">FEATURED BOOKS</h2>
          </div>
          <button
            class="font-mono text-xs tracking-widest uppercase text-text-3 hover:text-accent transition-colors duration-200 flex items-center gap-2"
            data-tab-target="books"
          >
            Browse All &rarr;
          </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredBooks.map((book) => (
            <BookCard book={book} />
          ))}
        </div>
      </div>
    </section>

    <!-- Brand statement section -->
    <section class="py-24 px-6 md:px-12 border-t border-border">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-display text-[clamp(28px,4vw,52px)] tracking-wide leading-[1.05] text-text/80 gsap-fade-up">
          SHORT-FORM CONTENT.<br/>
          <span class="text-accent">LONG-LASTING IMPACT.</span>
        </p>
        <p class="font-mono text-xs tracking-widest uppercase text-text-3 mt-6 gsap-fade-up">
          Thoughts Evoked Media &mdash; Where books meet short-form culture
        </p>
      </div>
    </section>

    <Footer />
  </div>

  <!-- PAGE: Trailers -->
  <div id="page-trailers" class="page">
    <section class="pt-28 pb-16 px-6 md:px-12">
      <div class="max-w-6xl mx-auto">
        <!-- Section header -->
        <div class="mb-10 gsap-fade-up">
          <span class="font-mono text-xs tracking-widest uppercase text-accent mb-2 block">Short-Form</span>
          <h2 class="font-display text-[clamp(36px,6vw,64px)] tracking-wide leading-[0.95] mb-4">ALL TRAILERS</h2>
          <p class="text-text-2 max-w-lg">9:16 vertical promos for every book in the collection. Watch, then click to read.</p>
        </div>

        <!-- Filter bar (reuses genre filter) -->
        <FilterBar />

        <!-- Trailers grid — 9:16 vertical cards -->
        <div class="trailers-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {BOOKS.map((book, i) => (
            <TrailerCard book={book} index={i} panelIdPrefix="trailers-page" />
          ))}
        </div>
      </div>
    </section>
    <Footer />
  </div>

  <!-- PAGE: Books -->
  <div id="page-books" class="page">
    <section class="pt-28 pb-16 px-6 md:px-12">
      <div class="max-w-6xl mx-auto">
        <!-- Section header -->
        <div class="mb-8 gsap-fade-up">
          <span class="font-mono text-xs tracking-widest uppercase text-accent mb-2 block">Library</span>
          <h2 class="font-display text-[clamp(36px,6vw,64px)] tracking-wide leading-[0.95] mb-4">ALL BOOKS</h2>
          <p class="text-text-2 max-w-lg mb-6">Browse the full collection. Filter by genre. Every title is DRM-free and delivered instantly.</p>
        </div>

        <!-- Filter bar -->
        <FilterBar />

        <!-- Book grid -->
        <div class="book-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {BOOKS.map((book) => (
            <BookCard book={book} />
          ))}
        </div>
      </div>
    </section>
    <Footer />
  </div>
</Base>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initPageAnimations() {
    gsap.utils.toArray('.gsap-fade-up').forEach((el: any) => {
      gsap.fromTo(el,
        { opacity: 0, y: 32 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 90%',
            once: true,
          },
        }
      );
    });

    gsap.utils.toArray('.video-card').forEach((card: any, i: number) => {
      gsap.fromTo(card,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: card,
            start: 'top 90%',
            once: true,
          },
          delay: (i % 3) * 0.08,
        }
      );
    });

    gsap.utils.toArray('.book-card').forEach((card: any, i: number) => {
      gsap.fromTo(card,
        { opacity: 0, y: 32 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: card,
            start: 'top 90%',
            once: true,
          },
          delay: (i % 3) * 0.06,
        }
      );
    });
  }

  // Keep overlay icon state in sync with each video's actual playback state
  function initVideoPlayback() {
    document.querySelectorAll('.video-card').forEach(card => {
      const video = card.querySelector<HTMLVideoElement>('.video-player');
      const playIcon = card.querySelector('.play-icon');
      const pauseIcon = card.querySelector('.pause-icon');
      if (!video || card.dataset.videoInit === 'true') return;

      const showPlayIcon = () => {
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
      };

      const showPauseIcon = () => {
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
      };

      showPlayIcon();
      video.addEventListener('play', showPauseIcon);
      video.addEventListener('pause', showPlayIcon);
      video.addEventListener('ended', showPlayIcon);
      card.dataset.videoInit = 'true';
    });
  }

  // Book panel toggle/close logic
  function initPanels() {
    let openPanelId: string | null = null;

    function openPanel(panelId: string) {
      const panel = document.getElementById(panelId);
      const toggle = document.querySelector(`[data-panel-id="${panelId}"].panel-toggle`);
      const icon = toggle?.querySelector('.toggle-icon');
      const label = toggle?.querySelector('.toggle-label');
      if (!panel) return;

      if (openPanelId && openPanelId !== panelId) {
        closePanel(openPanelId);
      }

      openPanelId = panelId;
      panel.setAttribute('aria-hidden', 'false');

      gsap.to(panel, {
        height: 'auto',
        opacity: 1,
        duration: 0.5,
        ease: 'power3.out',
      });

      if (icon) gsap.to(icon, { rotation: 180, duration: 0.3 });
      if (label) label.textContent = 'Hide Details';
    }

    function closePanel(panelId: string) {
      const panel = document.getElementById(panelId);
      const toggle = document.querySelector(`[data-panel-id="${panelId}"].panel-toggle`);
      const icon = toggle?.querySelector('.toggle-icon');
      const label = toggle?.querySelector('.toggle-label');
      if (!panel) return;

      panel.setAttribute('aria-hidden', 'true');
      if (openPanelId === panelId) openPanelId = null;

      gsap.to(panel, {
        height: 0,
        opacity: 0,
        duration: 0.35,
        ease: 'power2.in',
      });

      if (icon) gsap.to(icon, { rotation: 0, duration: 0.3 });
      if (label) label.textContent = 'About This Book';
    }

    document.querySelectorAll('.panel-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-panel-id')!;
        if (openPanelId === id) {
          closePanel(id);
        } else {
          openPanel(id);
        }
      });
    });

    document.querySelectorAll('.panel-close').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-panel-id')!;
        closePanel(id);
      });
    });
  }

  // Genre filter — scoped to the page the filter button lives in
  function initFilter() {
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const page = btn.closest('.page');
        if (!page) return;

        // Reset all filter buttons within this page
        page.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('active', 'bg-accent', 'text-bg', 'border-accent');
          b.classList.add('text-text-2', 'border-border');
        });
        btn.classList.add('active', 'bg-accent', 'text-bg', 'border-accent');
        btn.classList.remove('text-text-2', 'border-border');

        const genre = btn.getAttribute('data-genre');
        const cards = [...page.querySelectorAll('.video-card, .book-card')];

        const filtered = genre === 'all'
          ? cards
          : cards.filter(c => c.getAttribute('data-genre') === genre);
        const hidden = cards.filter(c => !filtered.includes(c));

        gsap.to(hidden, {
          opacity: 0,
          scale: 0.95,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => hidden.forEach((c: any) => c.style.display = 'none'),
        });

        filtered.forEach((c: any) => c.style.display = 'flex');
        gsap.fromTo(filtered,
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out', stagger: 0.06 }
        );
      });
    });
  }

  // Click-to-focus video card animation for cinematic playback emphasis
  function initVideoFocus() {
    const backdrop = document.createElement('div');
    backdrop.className = 'video-focus-backdrop';
    document.body.appendChild(backdrop);

    const companionPanel = document.createElement('aside');
    companionPanel.className = 'video-focus-companion';
    companionPanel.setAttribute('aria-hidden', 'true');
    document.body.appendChild(companionPanel);

    let activeCard: HTMLElement | null = null;
    let activePlaceholder: HTMLDivElement | null = null;

    const escapeHtml = (value: string) => value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    function closeFocusedCard() {
      if (!activeCard) return;
      const cardToClose = activeCard;
      const placeholder = activePlaceholder;
      activeCard = null;
      activePlaceholder = null;
      document.body.classList.remove('video-focus-lock');
      backdrop.style.pointerEvents = 'none';

      gsap.to(backdrop, { autoAlpha: 0, duration: 0.25, ease: 'power2.inOut' });
      if (placeholder) {
        const baseLeft = Number(cardToClose.dataset.focusBaseLeft || '0');
        const baseTop = Number(cardToClose.dataset.focusBaseTop || '0');
        const targetRect = placeholder.getBoundingClientRect();

        gsap.to(cardToClose, {
          x: targetRect.left - baseLeft,
          y: targetRect.top - baseTop,
          scale: 1,
          duration: 0.45,
          ease: 'power3.inOut',
          onComplete: () => {
            cardToClose.classList.remove('video-card-focus-active');
            placeholder.replaceWith(cardToClose);
            gsap.set(cardToClose, { clearProps: 'x,y,scale' });
            cardToClose.style.position = '';
            cardToClose.style.left = '';
            cardToClose.style.top = '';
            cardToClose.style.width = '';
            cardToClose.style.height = '';
            cardToClose.style.zIndex = '';
            cardToClose.style.margin = '';
            delete cardToClose.dataset.focusBaseLeft;
            delete cardToClose.dataset.focusBaseTop;
          },
        });
      }

      gsap.to(companionPanel, {
        autoAlpha: 0,
        x: 20,
        duration: 0.25,
        ease: 'power2.inOut',
        onComplete: () => {
          companionPanel.innerHTML = '';
          companionPanel.style.pointerEvents = 'none';
          companionPanel.setAttribute('aria-hidden', 'true');
        },
      });
    }

    function focusCard(card: HTMLElement) {
      if (activeCard === card) return;
      if (activeCard) closeFocusedCard();

      const rect = card.getBoundingClientRect();
      const placeholder = document.createElement('div');
      placeholder.className = 'video-focus-placeholder';
      placeholder.style.width = `${rect.width}px`;
      placeholder.style.height = `${rect.height}px`;
      card.after(placeholder);

      card.style.position = 'fixed';
      card.style.left = `${rect.left}px`;
      card.style.top = `${rect.top}px`;
      card.style.width = `${rect.width}px`;
      card.style.height = `${rect.height}px`;
      card.style.zIndex = '90';
      card.style.margin = '0';
      card.dataset.focusBaseLeft = `${rect.left}`;
      card.dataset.focusBaseTop = `${rect.top}`;
      document.body.appendChild(card);

      const gap = 24;
      const maxFocusHeight = window.innerHeight * 0.88;
      const targetVideoWidth = Math.min(window.innerWidth * 0.44, 420);
      const scaleByWidth = targetVideoWidth / rect.width;
      const scaleByHeight = maxFocusHeight / rect.height;
      const scale = Math.min(scaleByWidth, scaleByHeight);
      const scaledVideoWidth = rect.width * scale;

      const maxBookWidth = Math.min(window.innerWidth * 0.4, 420);
      const availableBookWidth = window.innerWidth * 0.92 - scaledVideoWidth - gap;
      const bookWidth = Math.min(maxBookWidth, Math.max(220, availableBookWidth));
      const pairWidth = scaledVideoWidth + gap + bookWidth;

      const cardCenterX = rect.left + rect.width / 2;
      const cardCenterY = rect.top + rect.height / 2;
      const viewportCenterX = window.innerWidth / 2;
      const viewportCenterY = window.innerHeight / 2;
      const targetVideoCenterX = viewportCenterX - (pairWidth - scaledVideoWidth) / 2;

      const title = escapeHtml(card.dataset.title || 'Book');
      const tagline = escapeHtml(card.dataset.tagline || '');
      const description = escapeHtml(card.dataset.description || '');
      const coverUrl = card.dataset.coverUrl || '';
      const buyUrl = card.dataset.buyUrl || '';
      const ctaLabel = escapeHtml(card.dataset.ctaLabel || 'View Book');

      const coverHtml = coverUrl
        ? `<img src="${coverUrl}" alt="${title} cover" class="video-focus-cover" />`
        : `<div class="video-focus-cover video-focus-cover-placeholder">${title}</div>`;

      const ctaHtml = buyUrl && buyUrl !== '#'
        ? `<div class="video-focus-book-actions"><span class="video-focus-cta">${ctaLabel} &rarr;</span></div>`
        : '<div class="video-focus-book-actions"><span class="video-focus-soon">Coming soon</span></div>';

      const bookCardInnerHtml = `
        ${coverHtml}
        ${ctaHtml}
        <div class="video-focus-book-copy">
          <p class="video-focus-book-kicker">E-BOOK</p>
          <h3 class="video-focus-book-title">${title}</h3>
          <p class="video-focus-book-tagline">${tagline}</p>
          <p class="video-focus-book-description">${description}</p>
        </div>
      `;

      companionPanel.innerHTML = buyUrl && buyUrl !== '#'
        ? `<a href="${buyUrl}" target="_blank" rel="noopener noreferrer" class="video-focus-book-card video-focus-book-card-link">${bookCardInnerHtml}</a>`
        : `<div class="video-focus-book-card">${bookCardInnerHtml}</div>`;

      activeCard = card;
      activePlaceholder = placeholder;
      card.classList.add('video-card-focus-active');
      document.body.classList.add('video-focus-lock');
      backdrop.style.pointerEvents = 'auto';

      companionPanel.style.width = `${bookWidth}px`;
      companionPanel.style.left = `${targetVideoCenterX + scaledVideoWidth / 2 + gap}px`;
      companionPanel.style.top = `${viewportCenterY}px`;
      companionPanel.style.pointerEvents = 'auto';
      companionPanel.setAttribute('aria-hidden', 'false');

      gsap.set(companionPanel, { x: 20, yPercent: -50, autoAlpha: 0 });
      gsap.to(companionPanel, { autoAlpha: 1, x: 0, duration: 0.35, ease: 'power3.out', delay: 0.1 });

      gsap.to(backdrop, { autoAlpha: 1, duration: 0.3, ease: 'power2.out' });
      gsap.to(card, {
        x: targetVideoCenterX - cardCenterX,
        y: viewportCenterY - cardCenterY,
        scale,
        duration: 0.55,
        ease: 'power3.out',
      });
    }

    backdrop.addEventListener('click', closeFocusedCard);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeFocusedCard();
    });

    window.addEventListener('resize', () => {
      if (activeCard) closeFocusedCard();
    });

    // Close focus before tab animations run so the card is never trapped in a
    // hidden page stacking context (which would put it behind the backdrop).
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (activeCard) closeFocusedCard();
      });
    });

    document.querySelectorAll('.video-card').forEach((card) => {
      if (card.dataset.focusInit === 'true') return;

      const video = card.querySelector<HTMLVideoElement>('.video-player');
      if (!video) return;

      video.addEventListener('click', (event) => {
        event.stopPropagation();

        if (activeCard === card) {
          closeFocusedCard();
        } else {
          focusCard(card as HTMLElement);
        }
      });

      card.dataset.focusInit = 'true';
    });
  }

  // Home page "View All" / "Browse All" buttons route to correct tab
  function initHomeCTAs() {
    document.querySelectorAll('[data-tab-target]').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab-target');
        if (tabId) {
          const tabBtn = document.querySelector(`[data-tab="${tabId}"]`) as HTMLButtonElement;
          tabBtn?.click();
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initPageAnimations();
    initVideoPlayback();
    initPanels();
    initFilter();
    initHomeCTAs();
    initVideoFocus();
  });
</script>


<style is:global>
  .video-focus-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(5, 6, 10, 0.78);
    backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    z-index: 70;
    pointer-events: none;
  }

  body.video-focus-lock {
    overflow: hidden;
  }

  .video-focus-companion {
    position: fixed;
    z-index: 85;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .video-focus-book-card {
    background: rgba(12, 13, 20, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
    display: flex;
    flex-direction: column;
    max-height: 88vh;
    color: inherit;
    text-decoration: none;
  }

  .video-focus-cover {
    width: 100%;
    max-height: 42vh;
    object-fit: contain;
    background: rgba(4, 6, 12, 0.9);
  }

  .video-focus-cover-placeholder {
    display: grid;
    place-items: center;
    background: linear-gradient(140deg, #6f86ff, #ad5cf0);
    color: #fff;
    font-family: var(--font-display, serif);
    font-size: 1.125rem;
    text-align: center;
    padding: 1rem;
  }

  .video-focus-book-copy {
    padding: 1rem;
    display: grid;
    gap: 0.6rem;
    overflow: auto;
  }

  .video-focus-book-kicker {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent, #8db5ff);
    margin: 0;
  }

  .video-focus-book-title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.1;
  }

  .video-focus-book-tagline,
  .video-focus-book-description {
    margin: 0;
    color: rgba(232, 236, 255, 0.82);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .video-focus-book-actions {
    padding: 0.75rem 1rem 0.15rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .video-focus-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.65rem 1rem;
    border-radius: 9999px;
    background: var(--color-accent, #8db5ff);
    color: #05060a;
    text-decoration: none;
  }

  .video-focus-book-card-link {
    cursor: pointer;
  }

  .video-focus-book-card-link:hover .video-focus-cta {
    filter: brightness(1.05);
  }

  .video-focus-placeholder {
    border-radius: 1rem;
  }

  .video-focus-soon {
    font-size: 0.75rem;
    color: rgba(232, 236, 255, 0.72);
  }
</style>
